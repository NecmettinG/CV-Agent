% =====================================================================
% resume.tex.j2 - the CV template (Cambridge-Oxford style, from
% samples/CV Example.pdf). Rendered by cv_agent/templating.py, which uses
% LaTeX-safe delimiters (VAR for variables, BLOCK for logic). Engine: Tectonic.
%
% Structure: a typed header + EXPERIENCE + EDUCATION, then a loop over
% cv.sections. Each section carries its OWN heading (section.title) and a `kind`
% that selects the body layout (list / skills / entries / text), so any section
% a CV has is rendered under its own name. Empty sections are skipped.
% =====================================================================
\documentclass[11pt,a4paper]{article}

\usepackage[a4paper,top=1.5cm,bottom=1.5cm,left=2cm,right=2cm]{geometry}

% fontspec alone already gives XeTeX a Unicode-capable default (Latin Modern,
% which covers Turkish). The block below upgrades to Termes + a symbol fallback;
% render.py re-renders with fallback=true (dropping this block) if the rich
% setup fails to compile, e.g. a font file cannot be resolved on a bare host.
\usepackage{fontspec}
\BLOCK{ if not fallback }
\setmainfont{texgyretermes}[
  Extension      = .otf,
  UprightFont    = *-regular,
  BoldFont       = *-bold,
  ItalicFont     = *-italic,
  BoldItalicFont = *-bolditalic,
]

% Fallback for glyphs Termes lacks (e.g. the Turkish Lira sign ₺).
\usepackage{newunicodechar}
\newfontfamily\fallbacksymbol{DejaVuSans}[Extension=.ttf]
\newunicodechar{₺}{{\fallbacksymbol ₺}}
\BLOCK{ endif }

\usepackage[normalem]{ulem}   % wrap-safe underlines for links
\usepackage{enumitem}
\usepackage{multicol}
\usepackage{hyperref}
\hypersetup{hidelinks, pdftitle={\VAR{ cv.name | e } - CV}, pdfauthor={\VAR{ cv.name | e }}}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{empty}
\setlength{\columnsep}{1.5em}
\newlength{\lvl}\setlength{\lvl}{1.5em}
\newlength{\entrygap}\setlength{\entrygap}{7pt}
\newlength{\subgap}\setlength{\subgap}{5pt}

% Bullet lists for highlights / dynamic sections (single column, ATS-safe).
\setlist[itemize,1]{leftmargin=2.6em, itemsep=1pt, topsep=2pt, parsep=0pt, label=\textbullet}
\setlist[itemize,2]{leftmargin=1.5em, itemsep=0.5pt, topsep=1pt, parsep=0pt, label={$\circ$}}

\newcommand{\cvsection}[1]{%
  \vspace{6pt}%
  {\bfseries #1}\par
  \vspace{1.5pt}%
  \hrule height 0.6pt%
  \vspace{6pt}%
}
% Links are emitted inline as \href{url}{\uline{label}} (not wrapped in a macro):
% hyperref's URL normaliser only handles specials (%, #, ~, ...) when \href reads
% the raw URL directly from the source, which an undelimited macro arg would break.
\newcommand{\rolehead}[2]{\noindent\textbf{#1}\hfill #2\par}
\newcommand{\subhead}[1]{\noindent\textbf{#1}\par}
\newcommand{\techline}[1]{\noindent\textit{#1}\par}
\newcommand{\descpar}[1]{{\advance\leftskip by \lvl\noindent #1\par}}
\newcommand{\contactline}[1]{{\advance\leftskip by \lvl\noindent\small #1\par}}

\begin{document}

% ----------------------------- Header ------------------------------
\begin{center}
  {\LARGE\bfseries \VAR{ cv.name | uc(cv.language) | e }}\\[3pt]
\BLOCK{ if cv.headline }
  {\large \VAR{ cv.headline | e }}\\[3pt]
\BLOCK{ endif }
\BLOCK{ set ns = namespace(parts=[]) }
\BLOCK{ if cv.contact.location }\BLOCK{ set ns.parts = ns.parts + [cv.contact.location | e] }\BLOCK{ endif }
\BLOCK{ if cv.contact.phone }\BLOCK{ set ns.parts = ns.parts + ['\\href{tel:' ~ cv.contact.phone ~ '}{\\uline{' ~ (cv.contact.phone | e) ~ '}}'] }\BLOCK{ endif }
\BLOCK{ if cv.contact.email }\BLOCK{ set ns.parts = ns.parts + ['\\href{mailto:' ~ cv.contact.email ~ '}{\\uline{' ~ (cv.contact.email | e) ~ '}}'] }\BLOCK{ endif }
\BLOCK{ for l in cv.contact.links }\BLOCK{ set ns.parts = ns.parts + ['\\href{' ~ l.url ~ '}{\\uline{' ~ (l.label | e) ~ '}}'] }\BLOCK{ endfor }
\BLOCK{ if ns.parts }
  {\VAR{ ns.parts | join(' – ') }}\\[3pt]
\BLOCK{ endif }
\BLOCK{ if cv.summary and (cv.summary | length) <= summary_threshold }
  {\itshape \VAR{ cv.summary | e }}
\BLOCK{ endif }
\end{center}
\vspace{4pt}

% -------- Profile / cover letter (only a long summary lands here) ---------
\BLOCK{ if cv.summary and (cv.summary | length) > summary_threshold }
\cvsection{\VAR{ t.profile | uc(cv.language) }}
\noindent \VAR{ cv.summary | e }\par
\BLOCK{ endif }

% --------------------------- Experience ----------------------------
\BLOCK{ if cv.experience }
\cvsection{\VAR{ t.experience | uc(cv.language) }}
\BLOCK{ for entry in cv.experience }
\BLOCK{ if entry.is_umbrella }
\rolehead{\VAR{ entry.company | e }}{\VAR{ entry.date_range | range_a(cv.language) }}
\vspace{2pt}
{\advance\leftskip by \lvl
\BLOCK{ for sr in entry.sub_roles }
  \subhead{\VAR{ sr.company | e } - \VAR{ sr.title | e }}
\BLOCK{ if sr.tech_stack }
  \techline{\VAR{ sr.tech_stack | join(', ') | e }}
\BLOCK{ endif }
\BLOCK{ if sr.description or sr.links }
  \descpar{\VAR{ sr.description | e }\BLOCK{ if sr.links } \BLOCK{ for l in sr.links }\href{\VAR{ l.url }}{\uline{\VAR{ l.label | e }}}\BLOCK{ if not loop.last }, \BLOCK{ endif }\BLOCK{ endfor }\BLOCK{ endif }}
\BLOCK{ endif }
\BLOCK{ if sr.highlights }
\begin{itemize}
\BLOCK{ for h in sr.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ if not loop.last }
  \vspace{\subgap}
\BLOCK{ endif }
\BLOCK{ endfor }
}
\BLOCK{ else }
\rolehead{\VAR{ entry.company | e } - \VAR{ entry.title | e }}{\VAR{ entry.date_range | range_a(cv.language) }}
\BLOCK{ if entry.tech_stack }
\techline{\VAR{ entry.tech_stack | join(', ') | e }}
\BLOCK{ endif }
\BLOCK{ if entry.description or entry.links }
\descpar{\VAR{ entry.description | e }\BLOCK{ if entry.links } \BLOCK{ for l in entry.links }\href{\VAR{ l.url }}{\uline{\VAR{ l.label | e }}}\BLOCK{ if not loop.last }, \BLOCK{ endif }\BLOCK{ endfor }\BLOCK{ endif }}
\BLOCK{ endif }
\BLOCK{ if entry.highlights }
\begin{itemize}
\BLOCK{ for h in entry.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ endif }
\BLOCK{ if not loop.last }
\vspace{\entrygap}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% ---------------------------- Education ----------------------------
\BLOCK{ if cv.education }
\cvsection{\VAR{ t.education | uc(cv.language) }}
\BLOCK{ for edu in cv.education }
\BLOCK{ if edu.url }
\noindent\textbf{\href{\VAR{ edu.url }}{\uline{\VAR{ edu.institution | e }}}}\hfill \VAR{ edu.location | e }\\
\BLOCK{ else }
\noindent\textbf{\VAR{ edu.institution | e }}\hfill \VAR{ edu.location | e }\\
\BLOCK{ endif }
\textit{\VAR{ edu.degree | e }}\hfill \VAR{ edu.date_range | range_years(cv.language) }\par
\BLOCK{ if edu.highlights }
\begin{itemize}
\BLOCK{ for h in edu.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\BLOCK{ if edu.links }
\begin{itemize}
\BLOCK{ for l in edu.links }
  \item \href{\VAR{ l.url }}{\uline{\VAR{ l.label | e }}}
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\end{itemize}
\BLOCK{ elif edu.links }
\begin{itemize}
\BLOCK{ for l in edu.links }
  \item \href{\VAR{ l.url }}{\uline{\VAR{ l.label | e }}}
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ if not loop.last }
\vspace{\entrygap}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% ------------------------- Dynamic sections ------------------------
\BLOCK{ for section in cv.sections }
\BLOCK{ if section.has_content }
\cvsection{\VAR{ section.title | uc(cv.language) }}
\BLOCK{ if section.kind == 'skills' and section.bullets }
\begin{multicols}{2}
\begin{itemize}[leftmargin=1.4em, itemsep=1pt, topsep=2pt, parsep=0pt, label=\textbullet]
\BLOCK{ for b in section.bullets }
  \item \VAR{ b | e }
\BLOCK{ endfor }
\end{itemize}
\end{multicols}
\BLOCK{ elif section.kind == 'entries' and section.entries }
\BLOCK{ for e in section.entries }
\BLOCK{ if e.url }\rolehead{\href{\VAR{ e.url }}{\uline{\VAR{ e.title | e }}}}{\VAR{ e.date_range | range_a(cv.language) }}\BLOCK{ else }\rolehead{\VAR{ e.title | e }}{\VAR{ e.date_range | range_a(cv.language) }}\BLOCK{ endif }
\BLOCK{ if e.detail }\descpar{\VAR{ e.detail | e }}\BLOCK{ endif }
\BLOCK{ set ec = namespace(parts=[]) }
\BLOCK{ if e.phone }\BLOCK{ set ec.parts = ec.parts + ['\\href{tel:' ~ e.phone ~ '}{\\uline{' ~ (e.phone | e) ~ '}}'] }\BLOCK{ endif }
\BLOCK{ if e.email }\BLOCK{ set ec.parts = ec.parts + ['\\href{mailto:' ~ e.email ~ '}{\\uline{' ~ (e.email | e) ~ '}}'] }\BLOCK{ endif }
\BLOCK{ for l in e.links }\BLOCK{ set ec.parts = ec.parts + ['\\href{' ~ l.url ~ '}{\\uline{' ~ (l.label | e) ~ '}}'] }\BLOCK{ endfor }
\BLOCK{ if ec.parts }\contactline{\VAR{ ec.parts | join(' \\textbullet{} ') }}\BLOCK{ endif }
\BLOCK{ if e.highlights }
\begin{itemize}
\BLOCK{ for h in e.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ if not loop.last }
\vspace{\entrygap}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ elif section.kind == 'text' and section.text }
\noindent \VAR{ section.text | e }\par
\BLOCK{ elif section.bullets }
\begin{itemize}
\BLOCK{ for b in section.bullets }
  \item \VAR{ b | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ if section.note }
\vspace{\subgap}\noindent\textbf{\itshape \VAR{ section.note | e }}\par
\BLOCK{ endif }
\BLOCK{ endif }
\BLOCK{ endfor }

\end{document}
