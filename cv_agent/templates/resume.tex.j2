% =====================================================================
% resume.tex.j2 - Jinja2 template for CV Style A (Cambridge-Oxford, from
% samples/CV Example.pdf). Rendered by cv_agent/templating.py, which uses
% LaTeX-safe delimiters (VAR for variables, BLOCK for logic).
% Engine: Tectonic (XeTeX).
% =====================================================================
\documentclass[11pt,a4paper]{article}

\usepackage[a4paper,top=1.5cm,bottom=1.5cm,left=2cm,right=2cm]{geometry}

\usepackage{fontspec}
\setmainfont{texgyretermes}[
  Extension      = .otf,
  UprightFont    = *-regular,
  BoldFont       = *-bold,
  ItalicFont     = *-italic,
  BoldItalicFont = *-bolditalic,
]

% Fallback for glyphs Termes lacks (e.g. the Turkish Lira sign ₺).
\usepackage{newunicodechar}
\newfontfamily\fallbacksymbol{DejaVuSans}[Extension=.ttf]
\newunicodechar{₺}{{\fallbacksymbol ₺}}

\usepackage[normalem]{ulem}   % wrap-safe underlines for links
\usepackage{enumitem}
\usepackage{multicol}
\usepackage{hyperref}
\hypersetup{hidelinks, pdftitle={\VAR{ cv.name | e } - CV}, pdfauthor={\VAR{ cv.name | e }}}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{empty}
\setlength{\columnsep}{1.5em}
\newlength{\lvl}\setlength{\lvl}{1.5em}
\newlength{\entrygap}\setlength{\entrygap}{7pt}
\newlength{\subgap}\setlength{\subgap}{5pt}

\newcommand{\cvsection}[1]{%
  \vspace{6pt}%
  {\bfseries #1}\par
  \vspace{1.5pt}%
  \hrule height 0.6pt%
  \vspace{6pt}%
}
\newcommand{\ulink}[2]{\href{#1}{\uline{#2}}}
\newcommand{\rolehead}[2]{\noindent\textbf{#1}\hfill #2\par}
\newcommand{\subhead}[1]{\noindent\textbf{#1}\par}
\newcommand{\techline}[1]{\noindent\textit{#1}\par}
\newcommand{\descpar}[1]{{\advance\leftskip by \lvl\noindent #1\par}}

\begin{document}

% ----------------------------- Header ------------------------------
\begin{center}
  {\LARGE\bfseries \VAR{ cv.name | upper | e }}\\[3pt]
\BLOCK{ set ns = namespace(parts=[]) }
\BLOCK{ if cv.contact.location }\BLOCK{ set ns.parts = ns.parts + [cv.contact.location | e] }\BLOCK{ endif }
\BLOCK{ if cv.contact.phone }\BLOCK{ set ns.parts = ns.parts + ['\\ulink{tel:' ~ cv.contact.phone ~ '}{' ~ (cv.contact.phone | e) ~ '}'] }\BLOCK{ endif }
\BLOCK{ if cv.contact.email }\BLOCK{ set ns.parts = ns.parts + ['\\ulink{mailto:' ~ cv.contact.email ~ '}{' ~ (cv.contact.email | e) ~ '}'] }\BLOCK{ endif }
\BLOCK{ for l in cv.contact.links }\BLOCK{ set ns.parts = ns.parts + ['\\ulink{' ~ l.url ~ '}{' ~ (l.label | e) ~ '}'] }\BLOCK{ endfor }
  {\VAR{ ns.parts | join(' – ') }}\\[3pt]
\BLOCK{ if cv.summary }
  {\itshape \VAR{ cv.summary | e }}
\BLOCK{ endif }
\end{center}
\vspace{4pt}

% --------------------------- Experience ----------------------------
\BLOCK{ if cv.experience }
\cvsection{EXPERIENCE}
\BLOCK{ for entry in cv.experience }
\BLOCK{ if entry.is_umbrella }
\rolehead{\VAR{ entry.company | e }}{\VAR{ entry.date_range | range_a }}
\vspace{2pt}
{\advance\leftskip by \lvl
\BLOCK{ for sr in entry.sub_roles }
  \subhead{\VAR{ sr.company | e } - \VAR{ sr.title | e }}
\BLOCK{ if sr.tech_stack }
  \techline{\VAR{ sr.tech_stack | join(', ') | e }}
\BLOCK{ endif }
\BLOCK{ if sr.description or sr.links }
  \descpar{\VAR{ sr.description | e }\BLOCK{ if sr.links } \BLOCK{ for l in sr.links }\ulink{\VAR{ l.url }}{\VAR{ l.label | e }}\BLOCK{ if not loop.last }, \BLOCK{ endif }\BLOCK{ endfor }\BLOCK{ endif }}
\BLOCK{ endif }
\BLOCK{ if not loop.last }
  \vspace{\subgap}
\BLOCK{ endif }
\BLOCK{ endfor }
}
\BLOCK{ else }
\rolehead{\VAR{ entry.company | e } - \VAR{ entry.title | e }}{\VAR{ entry.date_range | range_a }}
\BLOCK{ if entry.tech_stack }
\techline{\VAR{ entry.tech_stack | join(', ') | e }}
\BLOCK{ endif }
\BLOCK{ if entry.description or entry.links }
\descpar{\VAR{ entry.description | e }\BLOCK{ if entry.links } \BLOCK{ for l in entry.links }\ulink{\VAR{ l.url }}{\VAR{ l.label | e }}\BLOCK{ if not loop.last }, \BLOCK{ endif }\BLOCK{ endfor }\BLOCK{ endif }}
\BLOCK{ endif }
\BLOCK{ endif }
\BLOCK{ if not loop.last }
\vspace{\entrygap}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% ---------------------------- Education ----------------------------
\BLOCK{ if cv.education }
\cvsection{EDUCATION}
\BLOCK{ for edu in cv.education }
\noindent\textbf{\VAR{ edu.institution | e }}\hfill \VAR{ edu.location | e }\\
\textit{\VAR{ edu.degree | e }}\hfill \VAR{ edu.date_range | range_years }\par
\BLOCK{ if not loop.last }
\vspace{\entrygap}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% -------------------------- Experienced with -----------------------
\BLOCK{ if cv.skills and (cv.skills.primary or cv.skills.good_to_mention) }
\cvsection{EXPERIENCED WITH}
\BLOCK{ if cv.skills.primary }
\begin{multicols}{2}
\begin{itemize}[leftmargin=1.4em, itemsep=1pt, topsep=2pt, parsep=0pt, label=\textbullet]
\BLOCK{ for s in cv.skills.primary }
  \item \VAR{ s | e }
\BLOCK{ endfor }
\end{itemize}
\end{multicols}
\BLOCK{ endif }
\BLOCK{ if cv.skills.good_to_mention }
\noindent (Good to mention: \VAR{ cv.skills.good_to_mention | join(', ') | e })
\BLOCK{ endif }
\BLOCK{ endif }

\end{document}
