% =====================================================================
% resume2.tex.j2 - Jinja2 template for CV Style B (from samples/CV
% Example 2.pdf). Colon headings, bulleted entries, extra sections.
% Rendered by cv_agent/templating.py (LaTeX-safe VAR/BLOCK delimiters).
% Engine: Tectonic (XeTeX).
% =====================================================================
\documentclass[11pt,a4paper]{article}

\usepackage[a4paper,top=1.5cm,bottom=1.5cm,left=2cm,right=2cm]{geometry}

\usepackage{fontspec}
\setmainfont{texgyretermes}[
  Extension      = .otf,
  UprightFont    = *-regular,
  BoldFont       = *-bold,
  ItalicFont     = *-italic,
  BoldItalicFont = *-bolditalic,
]

\usepackage{newunicodechar}
\newfontfamily\fallbacksymbol{DejaVuSans}[Extension=.ttf]
\newunicodechar{₺}{{\fallbacksymbol ₺}}

\usepackage[normalem]{ulem}
\usepackage{enumitem}
\usepackage{hyperref}
\hypersetup{hidelinks, pdftitle={\VAR{ cv.name | e } - CV}, pdfauthor={\VAR{ cv.name | e }}}

\setlist[itemize,1]{leftmargin=1.4em, itemsep=1pt, topsep=2pt, parsep=0pt, label=\textbullet}
\setlist[itemize,2]{leftmargin=1.5em, itemsep=0.5pt, topsep=1pt, parsep=0pt, label={$\circ$}}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{empty}

\newcommand{\cvsection}[1]{\vspace{7pt}{\bfseries #1}\par\vspace{1.5pt}\hrule height 0.6pt\vspace{5pt}}
\newcommand{\ulink}[2]{\href{#1}{\uline{#2}}}
\newcommand{\bighead}[1]{\vspace{5pt}\noindent{\large\bfseries #1}\par}
\newcommand{\dateline}[1]{\noindent{\bfseries #1}\par}
\newcommand{\midhead}[1]{\vspace{5pt}\noindent{\bfseries #1}\par}

\begin{document}

% ----------------------------- Header ------------------------------
\begin{center}
  {\large\bfseries \VAR{ cv.name | upper | e }}\\[2pt]
\BLOCK{ set ns = namespace(parts=[]) }
\BLOCK{ if cv.contact.email }\BLOCK{ set ns.parts = ns.parts + ['\\ulink{mailto:' ~ cv.contact.email ~ '}{' ~ (cv.contact.email | e) ~ '}'] }\BLOCK{ endif }
\BLOCK{ for l in cv.contact.links }\BLOCK{ set ns.parts = ns.parts + ['\\ulink{' ~ l.url ~ '}{' ~ (l.label | e) ~ '}'] }\BLOCK{ endfor }
\BLOCK{ if ns.parts }
  {\VAR{ ns.parts | join(' \\textbar{} ') }}\\[2pt]
\BLOCK{ endif }
\BLOCK{ if cv.contact.phone }
  {\VAR{ cv.contact.phone | e }}
\BLOCK{ endif }
\end{center}
\BLOCK{ if cv.summary }
\vspace{3pt}
{\itshape \VAR{ cv.summary | e }}
\BLOCK{ endif }

% --------------------------- Experience ----------------------------
\BLOCK{ if cv.experience }
\cvsection{Experience:}
\BLOCK{ for entry in cv.experience }
\BLOCK{ set hdr = entry.company }
\BLOCK{ if entry.location and entry.work_mode }\BLOCK{ set hdr = hdr ~ ' (' ~ entry.location ~ ' - ' ~ entry.work_mode ~ ')' }\BLOCK{ elif entry.location }\BLOCK{ set hdr = hdr ~ ' (' ~ entry.location ~ ')' }\BLOCK{ endif }
\bighead{\VAR{ hdr | upper | e }}
\dateline{\VAR{ entry.date_range | range_b }: \VAR{ entry.title | e }\BLOCK{ if entry.employment_type } (\VAR{ entry.employment_type | upper | e })\BLOCK{ endif }}
\BLOCK{ if entry.highlights }
\begin{itemize}
\BLOCK{ for h in entry.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% ---------------------------- Education ----------------------------
\BLOCK{ if cv.education }
\cvsection{Education:}
\BLOCK{ for edu in cv.education }
\BLOCK{ set hdr = edu.institution }
\BLOCK{ if edu.date_range }\BLOCK{ set hdr = hdr ~ ': ' ~ (edu.date_range | range_b) }\BLOCK{ endif }
\BLOCK{ if edu.location }\BLOCK{ set hdr = hdr ~ ' (' ~ edu.location ~ ')' }\BLOCK{ endif }
\BLOCK{ if edu.url }\bighead{\ulink{\VAR{ edu.url }}{\VAR{ hdr | e }}}\BLOCK{ else }\bighead{\VAR{ hdr | e }}\BLOCK{ endif }
\BLOCK{ if edu.highlights or edu.links }
\begin{itemize}
\BLOCK{ for h in edu.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\BLOCK{ if edu.links }
\begin{itemize}
\BLOCK{ for l in edu.links }
  \item \ulink{\VAR{ l.url }}{\VAR{ l.label | e }}
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% --------------------------- Competitions --------------------------
\BLOCK{ if cv.competitions }
\cvsection{Competitions:}
\BLOCK{ for c in cv.competitions }
\BLOCK{ set hdr = c.title }
\BLOCK{ if c.location }\BLOCK{ set hdr = hdr ~ ' (' ~ c.location ~ ')' }\BLOCK{ endif }
\BLOCK{ if c.url }\midhead{\ulink{\VAR{ c.url }}{\VAR{ hdr | e }}}\BLOCK{ else }\midhead{\VAR{ hdr | e }}\BLOCK{ endif }
\BLOCK{ if c.highlights }
\begin{itemize}
\BLOCK{ for h in c.highlights }
  \item \VAR{ h | e }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }
\BLOCK{ endfor }
\BLOCK{ endif }

% ----------------------------- Projects ----------------------------
\BLOCK{ if cv.projects }
\cvsection{Projects:}
\begin{itemize}
\BLOCK{ for p in cv.projects }
  \item \BLOCK{ if p.url }\textbf{\ulink{\VAR{ p.url }}{\VAR{ p.name | e }:}}\BLOCK{ else }\textbf{\VAR{ p.name | e }:}\BLOCK{ endif }\BLOCK{ if p.description } \VAR{ p.description | e }\BLOCK{ endif }
\BLOCK{ if p.links }
  \begin{itemize}
\BLOCK{ for l in p.links }
    \item \textbf{\ulink{\VAR{ l.url }}{\VAR{ l.label | e }}}
\BLOCK{ endfor }
  \end{itemize}
\BLOCK{ endif }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }

% ------------------------------ Skills -----------------------------
\BLOCK{ if cv.skills and cv.skills.categories }
\cvsection{Skills:}
\begin{itemize}
\BLOCK{ for c in cv.skills.categories }
  \item \BLOCK{ if c.emphasis }\textbf{\itshape \VAR{ c.name | e }\BLOCK{ if c.detail }:\BLOCK{ endif }}\BLOCK{ else }\textbf{\VAR{ c.name | e }\BLOCK{ if c.detail }:\BLOCK{ endif }}\BLOCK{ endif }\BLOCK{ if c.detail } \VAR{ c.detail | e }\BLOCK{ endif }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }

% ---------------------------- Languages ----------------------------
\BLOCK{ if cv.languages }
\cvsection{Languages:}
\begin{itemize}
\BLOCK{ for lang in cv.languages }
  \item \VAR{ lang.name | e }\BLOCK{ if lang.level } (\VAR{ lang.level | e })\BLOCK{ endif }
\BLOCK{ endfor }
\end{itemize}
\BLOCK{ endif }

% ---------------------------- References ---------------------------
\BLOCK{ if cv.references or cv.references_note }
\cvsection{References:}
\BLOCK{ for r in cv.references }
\noindent \VAR{ r.name | e }\BLOCK{ if r.detail }: \VAR{ r.detail | e }\BLOCK{ endif }\par\vspace{3pt}
\BLOCK{ endfor }
\BLOCK{ if cv.references_note }
\noindent\textbf{\itshape \VAR{ cv.references_note | e }}
\BLOCK{ endif }
\BLOCK{ endif }

\end{document}
